{
  "description": "Daily water glass counter — one-tap widget to track hydration throughout the day.",
  "version": "1.0.0",
  "phase": "DEPLOYED",
  "dontProduceChips": false,
  "problem": {
    "statement": "",
    "context": "",
    "goals": []
  },
  "scenarios": [],
  "role": {
    "name": "worker",
    "persona": "You are the Water Counter agent. You help users track their daily water intake and stay hydrated. When users say things like 'log water', 'I drank a glass', 'how much water have I had', 'hydration', or ask to open the water counter, use water.log and water.get_today tools. Always open the water-counter widget via sys.focusUiPlugin so users can tap the big + button directly. When logging, confirm cheerfully with the current count vs the 8-glass daily goal. Keep responses short and encouraging.",
    "goals": [],
    "limitations": []
  },
  "glossary": {},
  "intents": {
    "supported": [],
    "thresholds": {
      "accept": 0.8,
      "clarify": 0.5,
      "reject": 0.5
    },
    "out_of_domain": {
      "action": "redirect",
      "message": ""
    }
  },
  "engine": {
    "rv2": {
      "max_iterations": 10,
      "iteration_timeout_ms": 30000,
      "allow_parallel_tools": false
    },
    "hlr": {
      "enabled": true,
      "critic": {
        "enabled": true,
        "check_interval": 3,
        "strictness": "medium"
      },
      "reflection": {
        "enabled": true,
        "depth": "shallow"
      },
      "replanning": {
        "enabled": true,
        "max_replans": 5
      }
    },
    "autonomy": {
      "level": "supervised"
    },
    "finalization_gate": {
      "enabled": true,
      "max_retries": 2
    },
    "internal_error": {
      "enabled": true,
      "tool_not_found": {
        "enter_resolution_after": 1,
        "retryable": false
      },
      "resolution": {
        "max_iterations": 1,
        "allowed_capabilities": [
          "read",
          "search",
          "document_output"
        ]
      },
      "loop_detection": {
        "enabled": true,
        "identical_call_threshold": 2
      }
    }
  },
  "toolbox_imports": [],
  "tools": [
