    },
    {
      "id": "mcp:browser-mcp:auth-webview",
      "name": "Auth WebView",
      "version": "1.7.0",
      "type": "ui",
      "description": "Generic authentication WebView — user signs in on their device. Supports OAuth code extraction (in-app WebView), cookie capture, and external-browser OAuth (ASWebAuthenticationSession via expo-web-browser). No passwords touch the LLM.",
      "render": {
        "mode": "adaptive",
        "iframeUrl": "/ui/login-webview/index.html",
        "reactNative": {
          "component": "AuthWebView"
        }
      },
      "capabilities": {
        "webview": true,
        "cookies": true,
        "haptics": true,
        "commands": [
          {
            "name": "openAuth",
            "description": "Open a URL for authentication. mode='cookie' captures cookies, mode='oauth' extracts authorization code from redirect (in-app WebView), mode='oauth_external' opens the URL in the system browser and polls platform.auth.status(service_id) until connected (for WebView-blocking providers like Google/Facebook).",
            "input_schema": {
              "type": "object",
              "properties": {
                "mode": {
                  "type": "string",
                  "enum": [
                    "oauth",
                    "cookie",
                    "oauth_external"
                  ]
                },
                "url": {
                  "type": "string"
                },
                "label": {
                  "type": "string"
                },
                "success_url_pattern": {
                  "type": "string"
                },
                "cookie_domain": {
                  "type": "string"
                },
                "session_token": {
                  "type": "string"
                },
                "redirect_url_pattern": {
                  "type": "string"
                },
                "callback_tool": {
                  "type": "string"
                },
                "callback_connector": {
                  "type": "string"
                },
                "submit_tool": {
                  "type": "string"
                },
                "submit_connector": {
                  "type": "string"
                },
                "service_id": {
                  "type": "string"
                },
                "poll_tool": {
                  "type": "string"
                },
                "poll_interval_ms": {
                  "type": "number"
                },
                "timeout_ms": {
                  "type": "number"
                }
              },
              "required": [
                "mode",
                "url"
              ]
            }
          }
        ]
      },
      "channels": [
        "command"
      ],
      "commands": [],
      "_source": "mcp_introspection",
      "_connector_id": "browser-mcp"
    },
    {
